# Gemini API key — get one free at https://aistudio.google.com/apikey
# Used for AI drink recipes (Gemini text models).
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API key — https://openrouter.ai/keys
# Used for cocktail images (black-forest-labs/flux.2-klein-4B via chat completions).
# Optional: if omitted, AI drink cards show a placeholder instead of a generated image.
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
